# Archivo de configuración de ejemplo
# Copia este archivo a .env y reemplaza los valores

# API de Groq (obtener en https://console.groq.com)
GROQ_API_KEY=tu_clave_groq_aqui

# Configuración de Ollama (si usas Ollama localmente)
OLLAMA_API_URL=http://localhost:11434/api/generate

# Configuración de la aplicación
ENV=development
DEBUG=True

# Configuración de la base de datos MySQL
DB_HOST=localhost
DB_USER=usuario_mysql
DB_PASSWORD=contraseña_mysql
DB_NAME=text_processor_db

# OCR opcional (solo si necesitas definir ruta manual de tesseract, por ejemplo en Windows)
# TESSERACT_CMD=D:\\tesseract\\tesseract.exe

# Clave secreta para JWT
SECRET_KEY=pon_una_clave_secreta_aqui
